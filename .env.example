# Copia este archivo a ".env" y completa los valores reales.
# NUNCA subas el archivo ".env" real a Git ni lo compartas.

# Puerto donde corre la aplicacion
PORT=3000

# Clave secreta para firmar las sesiones (usa un texto largo y aleatorio)
SESSION_SECRET=cambia-esto-por-un-texto-largo-y-aleatorio

# Clave secreta para proteccion CSRF (usa otro texto largo y aleatorio, distinto al de arriba)
CSRF_SECRET=cambia-esto-tambien-por-otro-texto-largo-y-aleatorio

# Ruta del archivo de base de datos SQLite (se crea solo si no existe).
# IMPORTANTE en Hostinger: usa una ruta ABSOLUTA fuera de la carpeta de la app
# (ej: /home/tu_usuario/astillero-datos/astillero.sqlite), porque cada vez que
# "redespliegas" desde GitHub, Hostinger reemplaza el contenido de la carpeta
# de la app por una copia limpia del repositorio y borraria este archivo si
# quedara adentro.
DATABASE_FILE=./data/astillero.sqlite

# Carpeta donde se guardan las fotos (original, miniatura y version web).
# Mismo cuidado que con DATABASE_FILE: en Hostinger usa una ruta absoluta
# fuera de la carpeta de la app (ej: /home/tu_usuario/astillero-datos/storage).
STORAGE_DIR=./storage

# Tamano maximo permitido por foto, en megabytes (limite tecnico del servidor)
MAX_FOTO_MB=40

# Tamano maximo permitido por video, en megabytes (limite tecnico del servidor)
MAX_VIDEO_MB=200

# Poner en "true" cuando el sitio ya corre con HTTPS real (Hostinger + Let's Encrypt)
COOKIES_SEGURAS=false
