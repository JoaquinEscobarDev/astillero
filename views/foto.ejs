<%- include('partials/head') %>
<%- include('partials/header') %>

  <a href="/carpetas/<%= carpeta.id %>" class="enlace-volver">&larr; Volver a <%= carpeta.nombre %></a>

  <div class="detalle-foto">
    <% if (foto.tipo === 'video') { %>
      <video
        src="<%= foto.procesando ? '/media/original/' + foto.ruta_original : '/media/web/' + foto.ruta_web %>"
        controls
        class="detalle-foto-imagen fade-in"
      ></video>
      <% if (foto.procesando) { %>
        <p class="texto-ayuda">
          Este video se está preparando para que se vea bien en todos los celulares. Puede tardar
          unos minutos; mientras tanto quizás no se reproduzca en tu navegador. Vuelve a entrar a
          esta página en un rato.
        </p>
      <% } %>
    <% } else { %>
      <img src="/media/web/<%= foto.ruta_web %>" alt="<%= foto.descripcion || carpeta.nombre %>" class="detalle-foto-imagen fade-in" />
      <a href="/media/original/<%= foto.ruta_original %>" class="boton boton-secundario" target="_blank" rel="noopener">Ver tamaño completo</a>
    <% } %>

    <p class="detalle-foto-fecha">
      <%= foto.tipo === 'video' ? 'Subido' : 'Subida' %> el
      <%= new Date(foto.fecha_subida.replace(' ', 'T') + 'Z').toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' }) %>
    </p>

    <p><%= foto.descripcion || 'Sin descripción todavía.' %></p>

    <% if (estaAutenticado) { %>
      <div class="detalle-foto-acciones">
        <a href="/fotos/<%= foto.id %>/editar" class="boton boton-secundario">Editar descripción</a>
        <a href="/fotos/<%= foto.id %>/eliminar" class="boton boton-peligro"><%= foto.tipo === 'video' ? 'Borrar video' : 'Borrar foto' %></a>
      </div>
    <% } %>
  </div>

<%- include('partials/pie') %>
