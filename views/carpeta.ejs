<%- include('partials/head') %>
<%- include('partials/header') %>

  <a href="/" class="enlace-volver">&larr; Volver al inicio</a>
  <h1><%= carpeta.nombre %></h1>

  <% if (estaAutenticado) { %>
    <div class="tarjeta">
      <h2>Subir fotos</h2>
      <p class="texto-ayuda">
        Elige fotos desde tu celular o cámara. No te preocupes por el tamaño, la página las prepara sola.
      </p>
      <form action="/carpetas/<%= carpeta.id %>/fotos" method="POST" enctype="multipart/form-data" class="formulario" id="formulario-subida">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label for="fotos" class="zona-arrastrar" id="zona-arrastrar">
          <span>Toca aquí para elegir fotos, o arrástralas a esta zona</span>
          <input type="file" id="fotos" name="fotos" accept="image/*" multiple />
        </label>
        <button type="submit" class="boton boton-primario boton-grande">Subir fotos</button>
      </form>
    </div>
  <% } %>

  <% if (fotos.length === 0) { %>
    <p class="texto-ayuda">Todavía no hay fotos en esta carpeta.</p>
  <% } %>

  <div class="grilla-fotos">
    <% fotos.forEach(function (foto) { %>
      <a href="/fotos/<%= foto.id %>" class="miniatura">
        <img src="/media/thumb/<%= foto.ruta_thumbnail %>" alt="<%= foto.descripcion || carpeta.nombre %>" loading="lazy" />
      </a>
    <% }); %>
  </div>

  <% if (estaAutenticado) { %>
    <a href="/carpetas/<%= carpeta.id %>/eliminar" class="boton boton-peligro">Borrar esta carpeta</a>
  <% } %>

<%- include('partials/pie') %>
<script src="/js/app.js"></script>
