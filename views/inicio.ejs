<%- include('partials/head') %>
<%- include('partials/header') %>

  <h1>Hola, <%= nombreUsuarioSesion %></h1>
  <p class="texto-ayuda">Aquí están tus carpetas de botes. Toca una para ver las fotos.</p>

  <div class="grilla-carpetas">
    <% carpetas.forEach(function (carpeta) { %>
      <div class="tarjeta-carpeta">
        <a href="/carpetas/<%= carpeta.id %>" class="tarjeta-carpeta-link">
          <div class="tarjeta-carpeta-portada">
            <% if (carpeta.portada) { %>
              <img src="/media/thumb/<%= carpeta.portada %>" alt="" loading="lazy" />
            <% } else { %>
              <svg class="icono-timon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 4a1 1 0 0 1 1 1v1.09a4 4 0 0 1 2.9 1.68l.94-.55a1 1 0 0 1 1 1.73l-.94.55a4 4 0 0 1 0 3.4l.94.55a1 1 0 1 1-1 1.73l-.94-.55A4 4 0 0 1 13 17.91V19a1 1 0 1 1-2 0v-1.09a4 4 0 0 1-2.9-1.68l-.94.55a1 1 0 1 1-1-1.73l.94-.55a4 4 0 0 1 0-3.4l-.94-.55a1 1 0 0 1 1-1.73l.94.55A4 4 0 0 1 11 7.09V6a1 1 0 0 1 1-1Zm0 6a2 2 0 1 0 2 2 2 2 0 0 0-2-2Z" fill="currentColor"/>
              </svg>
            <% } %>
          </div>
          <p class="tarjeta-carpeta-nombre"><%= carpeta.nombre %></p>
          <p class="tarjeta-carpeta-total"><%= carpeta.total_fotos %> foto<%= carpeta.total_fotos === 1 ? '' : 's' %></p>
        </a>
        <div class="tarjeta-carpeta-acciones">
          <a href="/carpetas/<%= carpeta.id %>/renombrar" class="boton boton-secundario boton-chico">Cambiar nombre</a>
          <a href="/carpetas/<%= carpeta.id %>/eliminar" class="boton boton-peligro boton-chico">Borrar</a>
        </div>
      </div>
    <% }); %>
  </div>

  <div class="tarjeta tarjeta-angosta">
    <h2>Crear una carpeta nueva</h2>
    <p class="texto-ayuda">Por ejemplo: "Goleta 1920" o "Bote pesquero chilote".</p>
    <form action="/carpetas" method="POST" class="formulario formulario-en-linea">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label for="nombre" class="visualmente-oculto">Nombre de la carpeta</label>
      <input type="text" id="nombre" name="nombre" placeholder="Nombre del proyecto de bote" required />
      <button type="submit" class="boton boton-primario">Crear carpeta</button>
    </form>
  </div>

<%- include('partials/pie') %>
